{
  "name": "clip-empire-dashboard",
  "version": "1.0.0",
  "description": "Clip Empire Control Center",
  "main": "main.js",
  "author": "Clip Empire",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.clipempire.dashboard",
    "productName": "Clip Empire Dashboard",
    "directories": {
      "buildResources": ".",
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "../dashboard/icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "../dashboard/**/*",
      "../data/**/*",
      "../analytics/**/*"
    ]
  }
}
